{
  "manifest_version": 3,
  "name": "Peek Selection Popup",
  "version": "0.1.0",
  "description": "Safari-like quick popup for short text selections.",
  "action": {
    "default_title": "Peek"
  },
  "permissions": [],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
