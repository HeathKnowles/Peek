{
  "manifest_version": 3,
  "name": "Peek Selection Popup",
  "version": "0.1.1",
  "description": "Safari-like quick popup for short text selections.",
  "icons": {
    "16": "logo.png",
    "32": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "action": {
    "default_title": "Peek",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": [
    "identity",
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content/peek-state.js",
        "content/peek-selection.js",
        "content/connectors/base.js",
        "content/connectors/google-forms.js",
        "content/connectors/wikipedia.js",
        "content/connectors/wiktionary.js",
        "content/connectors/duckduckgo.js",
        "content/connectors/stackoverflow.js",
        "content/peek-services.js",
        "content/peek-ui.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
